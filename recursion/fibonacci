input : 7
output : 0 1 1 2 3 5 8 

solution 1 :

def fibonacci(n):
    if n == 0:      # Base case
        return 0
    if n == 1:      # Base case
        return 1
    return fibonacci(n-1) + fibonacci(n-2)
n=int(input())
for i in range(n):
    print(fibonacci(i),end=" ")

