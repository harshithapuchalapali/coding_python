def palindrome(s):
    def check(left, right):
        # Base case
        if left >= right:
            return True

        # Characters don't match
        if s[left] != s[right]:
            return False

        # Recursive call
        return check(left + 1, right - 1)

    return check(0, len(s) - 1)
