#153(n=3)=1^3+5^3+3^3       1634(n=4)=1^4+6^4+3^4=4^4
         =3+125+9                    = 1+1296+81+256
    153  = 153                1634   = 1634

input : 153
output : 153 is an amstrong number

solution:

de amstrong_num(n):
  count = 0
  for i in n:
      count += int(i) ** len(n)
  if int(n)==count:
      print(f"{n} is an amstrong number")
  else:
      print(f"{n} is not an amstrong number")
n=input()
amstrong_num(n)
